@{
    ViewData["Title"] = "Home Page";
}

<div class="hero min-h-[75vh]" data-aos="fade-up">
    <div class="hero-content text-center">
        <div class="max-w-2xl">
            <div class="mb-4">
                <span class="badge badge-primary badge-outline px-4 py-3 rounded-full text-sm font-semibold mb-3">AI Powered</span>
            </div>
            
            <h1 class="text-5xl font-extrabold mb-6 tracking-tight text-gray-900">
                IntervIO – AI Interview Simulator
            </h1>
            
            <p class="py-6 text-xl text-gray-600">
                Practice technical interviews with AI feedback. Improve your skills and get ready for your dream job.
            </p>
            
            <div class="flex flex-col sm:flex-row justify-center gap-4 mt-4">
                <a asp-controller="Interview" asp-action="Setup" class="btn bg-indigo-600 hover:bg-indigo-700 text-white border-none rounded-full px-8 py-3 text-lg h-auto shadow-md hover:shadow-lg transition-all">
                    Start Interview
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 ml-2" viewBox="0 0 20 20" fill="currentColor">
                        <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
                    </svg>
                </a>
                <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline hover:bg-gray-50 border-gray-300 text-gray-700 rounded-full px-8 py-3 text-lg h-auto transition-all">
                    View Dashboard
                </a>
            </div>
        </div>
    </div>
</div>
