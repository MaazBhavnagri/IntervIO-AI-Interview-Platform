@{
    ViewData["Title"] = "Home Page";
}

<div class="row min-vh-75 align-items-center justify-content-center text-center fade-in">
    <div class="col-md-8 py-5 px-4 rounded-4" style="background: linear-gradient(135deg, rgba(79, 70, 229, 0.05), rgba(99, 102, 241, 0.05)); border: 1px solid rgba(79, 70, 229, 0.1);">
        
        <div class="mb-4">
            <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill fs-6 mb-3">AI Powered</span>
        </div>
        
        <h1 class="display-3 fw-bold mb-4" style="color: var(--text-main); letter-spacing: -1px;">AI Powered Interview Intelligence</h1>
        
        <p class="lead mb-5 mx-auto" style="max-width: 600px; color: var(--text-muted); font-size: 1.25rem;">
            Practice your interview skills using advanced AI and receive instant, personalized feedback to land your dream job.
        </p>
        
        <div>
            <a asp-controller="Interview" asp-action="Setup" class="btn btn-primary-modern btn-lg px-5 py-3 fs-5">
                Start Interview <span class="ms-2">→</span>
            </a>
            
            <div class="mt-4 text-muted small">
                Join thousands of candidates practicing today
            </div>
        </div>
        
    </div>
</div>
