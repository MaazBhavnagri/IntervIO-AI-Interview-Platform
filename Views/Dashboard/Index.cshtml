@model AIInterviewPractice.Models.DashboardStats
@{
    ViewData["Title"] = "Dashboard";
}

<div class="container mx-auto py-8 fade-in">
    <div class="flex flex-col md:flex-row justify-between items-center mb-8 border-b border-gray-200 pb-4">
        <h2 class="text-3xl font-extrabold text-gray-900">Performance Dashboard</h2>
    </div>

    <!-- Stats Row -->
    <div class="stats stats-vertical lg:stats-horizontal shadow-md w-full mb-10 border border-gray-100" data-aos="fade-up">
        
        <div class="stat bg-indigo-50/50">
            <div class="stat-figure text-indigo-500">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-8 h-8 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
            </div>
            <div class="stat-title text-indigo-700 font-bold tracking-wide">Total Interviews</div>
            <div class="stat-value text-indigo-600">@Model.TotalInterviews</div>
        </div>
        
        <div class="stat bg-blue-50/50">
            <div class="stat-figure text-blue-500">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-8 h-8 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
            </div>
            <div class="stat-title text-blue-700 font-bold tracking-wide">Average Score</div>
            <div class="stat-value text-gray-800">@Model.AverageScore.ToString("F1")%</div>
            <div class="stat-desc font-medium">Across all categories</div>
        </div>
        
        <div class="stat bg-green-50/50">
            <div class="stat-figure text-success">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-8 h-8 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path></svg>
            </div>
            <div class="stat-title text-green-700 font-bold tracking-wide">Best Topic</div>
            <div class="stat-value text-success text-2xl truncate" title="@Model.BestCategory">@Model.BestCategory</div>
        </div>
        
        <div class="stat bg-red-50/50">
            <div class="stat-figure text-error">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" class="inline-block w-8 h-8 stroke-current"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
            </div>
            <div class="stat-title text-red-700 font-bold tracking-wide">Needs Focus</div>
            <div class="stat-value text-error text-2xl truncate" title="@Model.WeakCategory">@Model.WeakCategory</div>
        </div>
        
    </div>

    @if (Model.TotalInterviews > 0 && Model.CategoryPerformance.Any())
    {
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-10">
            <div class="card bg-base-100 shadow-md border border-gray-100 p-6" data-aos="fade-right">
                <h3 class="text-xl font-bold mb-6 text-gray-800 border-b pb-2">Category Performance</h3>
                <div class="relative h-72 w-full">
                    <canvas id="categoryChart"></canvas>
                </div>
            </div>
            
            <div class="card bg-base-100 shadow-md border border-gray-100 p-6" data-aos="fade-left">
                <h3 class="text-xl font-bold mb-6 text-gray-800 border-b pb-2">Score History</h3>
                <div class="relative h-72 w-full">
                    <canvas id="historyChart"></canvas>
                </div>
            </div>
        </div>

        @section Scripts {
            <script>
                document.addEventListener('DOMContentLoaded', function() {
                    var ctxCategory = document.getElementById('categoryChart').getContext('2d');
                    var ctxHistory = document.getElementById('historyChart').getContext('2d');
                    
                    var catLabels = [];
                    var catData = [];
                    
                    @foreach (var kp in Model.CategoryPerformance)
                    {
                        @:catLabels.push('@kp.Key');
                        @:catData.push(@kp.Value);
                    }

                    var histLabels = [];
                    var histData = [];

                    @foreach (var lbl in Model.ScoreHistoryLabels)
                    {
                        @:histLabels.push('@lbl');
                    }
                    @foreach (var score in Model.ScoreHistory)
                    {
                        @:histData.push(@score);
                    }

                    // Configuration matching Tailwind colors
                    Chart.defaults.font.family = "'Inter', sans-serif";
                    Chart.defaults.color = '#6b7280'; // gray-500

                    new Chart(ctxCategory, {
                        type: 'bar',
                        data: {
                            labels: catLabels,
                            datasets: [{
                                label: 'Average Score (%)',
                                data: catData,
                                backgroundColor: 'rgba(79, 70, 229, 0.8)', // indigo-600
                                borderColor: 'rgba(79, 70, 229, 1)',
                                borderWidth: 1,
                                borderRadius: 6
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            scales: {
                                y: { 
                                    beginAtZero: true, 
                                    max: 100, 
                                    grid: { display: true, color: '#f3f4f6' },
                                    ticks: { font: { size: 12 } }
                                },
                                x: { 
                                    grid: { display: false },
                                    ticks: { font: { size: 12 } }
                                }
                            },
                            plugins: { 
                                legend: { display: false },
                                tooltip: {
                                    backgroundColor: 'rgba(17, 24, 39, 0.9)', // gray-900
                                    padding: 12,
                                    titleFont: { size: 14, weight: 'bold' },
                                    bodyFont: { size: 13 }
                                }
                            }
                        }
                    });

                    new Chart(ctxHistory, {
                        type: 'line',
                        data: {
                            labels: histLabels,
                            datasets: [{
                                label: 'Score History',
                                data: histData,
                                fill: true,
                                backgroundColor: 'rgba(16, 185, 129, 0.1)', // emerald-500 with opacity
                                borderColor: 'rgba(16, 185, 129, 1)',   // emerald-500
                                tension: 0.4,
                                pointBackgroundColor: 'rgba(16, 185, 129, 1)',
                                pointHoverRadius: 6
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            scales: {
                                y: { 
                                    beginAtZero: true, 
                                    max: 100,
                                    grid: { display: true, color: '#f3f4f6' },
                                    ticks: { font: { size: 12 } }
                                },
                                x: {
                                    grid: { display: false },
                                    ticks: { font: { size: 12 } }
                                }
                            },
                            plugins: { 
                                legend: { display: false },
                                tooltip: {
                                    backgroundColor: 'rgba(17, 24, 39, 0.9)', // gray-900
                                    padding: 12,
                                    titleFont: { size: 14, weight: 'bold' },
                                    bodyFont: { size: 13 }
                                }
                            }
                        }
                    });
                });
            </script>
        }
    }
    else
    {
        <div class="card bg-indigo-50/50 shadow-sm border border-indigo-100 text-center p-12 mt-8 max-w-2xl mx-auto" data-aos="zoom-in">
            <div class="text-6xl mb-6">📊</div>
            <h3 class="text-3xl font-extrabold text-gray-800 mb-4">No Analytics Yet</h3>
            <p class="text-gray-500 text-lg mb-8 leading-relaxed">Ready to test yourself? Complete some interviews to generate your personal performance charts.</p>
            <a asp-controller="Interview" asp-action="Setup" class="btn bg-indigo-600 hover:bg-indigo-700 text-white border-none rounded-full px-8 py-3 h-auto text-lg shadow-md hover:shadow-lg transition-all">Start an interview</a>
        </div>
    }
</div>
