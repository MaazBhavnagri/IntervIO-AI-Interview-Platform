@model AIInterviewPractice.Models.InterviewSettings
@{
    ViewData["Title"] = "Interview Setup";
}

<div class="row justify-content-center align-items-center min-vh-75 fade-in">
    <div class="col-md-8 col-lg-6">
        <div class="card-modern">
            <h2 class="text-center mb-4 fw-bold" style="color: var(--primary);">Interview Setup</h2>
            <form asp-action="Generate" method="post" enctype="multipart/form-data">
                <div class="row mb-4">
                    <div class="col-md-12">
                        <label class="form-label-modern mb-3">Interview Type</label>
                        <div class="d-flex gap-4">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="InterviewType" id="typeCategory" value="category" checked onchange="toggleInterviewType()">
                                <label class="form-check-label" for="typeCategory">
                                    Category Based Interview
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="InterviewType" id="typeResume" value="resume" onchange="toggleInterviewType()">
                                <label class="form-check-label" for="typeResume">
                                    Resume Based Interview
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row mb-4" id="resumeUploadSection" style="display:none;">
                    <div class="col-md-12">
                        <label class="form-label-modern">Upload Resume</label>
                        <input type="file" name="ResumeFile" class="form-control-modern w-100" accept=".pdf,.docx" />
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6 mb-3 mb-md-0" id="categorySection">
                        <label asp-for="Category" class="form-label-modern">Category</label>
                        <select asp-for="Category" class="form-select-modern w-100" id="categorySelect" onchange="toggleCustomCategory()">
                            <option value="DSA">DSA</option>
                            <option value="HR">HR</option>
                            <option value="System Design">System Design</option>
                            <option value="Other">Other</option>
                        </select>
                        <input type="text" id="customCategory" name="CustomCategory" class="form-control-modern w-100 mt-2" placeholder="Enter custom category" style="display:none" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="Difficulty" class="form-label-modern">Difficulty</label>
                        <select asp-for="Difficulty" class="form-select-modern w-100">
                            <option value="Easy">Easy</option>
                            <option value="Medium" selected>Medium</option>
                            <option value="Hard">Hard</option>
                        </select>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <label asp-for="QuestionCount" class="form-label-modern">Number of Questions</label>
                        <input type="number"
                               name="QuestionCount"
                               value="3"
                               min="1"
                               max="20"
                               class="form-control-modern w-100" />
                    </div>
                    <div class="col-md-6">
                        <label asp-for="PreferredTopic" class="form-label-modern">Preferred Topic (Optional)</label>
                        <input asp-for="PreferredTopic" class="form-control-modern w-100" placeholder="e.g. Binary Search" />
                    </div>
                </div>

                <div class="row mb-5">
                    <div class="col-md-6 mb-3 mb-md-0">
                        <label asp-for="EvaluationStrictness" class="form-label-modern">Evaluation Strictness</label>
                        <select asp-for="EvaluationStrictness" class="form-select-modern w-100">
                            <option value="Normal" selected>Normal</option>
                            <option value="Strict">Strict</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label-modern">Interview Timer (minutes)</label>
                        <input type="number" name="InterviewTimeMinutes" value="10" min="1" max="120" class="form-control-modern w-100" />
                        <small class="text-muted d-block mt-1">Interview will automatically submit when timer ends.</small>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary-modern w-100 py-3 fs-5">
                    Start Interview
                </button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleCustomCategory() {
            var select = document.getElementById("categorySelect");
            var input = document.getElementById("customCategory");
            if (select.value === "Other") {
                input.style.display = "block";
            } else {
                input.style.display = "none";
                input.value = "";
            }
        }

        function toggleInterviewType() {
            var typeCategory = document.getElementById("typeCategory");
            var categorySection = document.getElementById("categorySection");
            var resumeUploadSection = document.getElementById("resumeUploadSection");

            if (typeCategory.checked) {
                categorySection.style.display = "block";
                resumeUploadSection.style.display = "none";
            } else {
                categorySection.style.display = "none";
                resumeUploadSection.style.display = "block";
            }
        }
    </script>
}
