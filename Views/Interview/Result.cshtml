@model AIInterviewPractice.Models.InterviewSession
@{
    ViewData["Title"] = "Interview Result";
}

<div class="container mx-auto max-w-5xl py-8 fade-in">
    <div class="text-center mb-10" data-aos="fade-down">
        <h1 class="text-4xl font-extrabold text-indigo-700 mb-3">Interview Complete</h1>
        <p class="text-xl text-gray-500">Here is your detailed performance evaluation.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-12">
        <div class="md:col-span-5">
            <div class="card bg-base-100 shadow-md border border-gray-100 h-full flex flex-col items-center justify-center p-8" data-aos="fade-right">
                <h4 class="text-2xl font-bold mb-6 text-gray-800">Overall Score</h4>
                
                <div class="radial-progress text-primary font-bold text-3xl @(Model.Score >= 80 ? "text-success" : Model.Score >= 60 ? "text-warning" : "text-error")" style="--value:@Model.Score; --size:12rem; --thickness: 1rem;" role="progressbar">
                    @Model.Score<span class="text-xl text-gray-400 font-normal">%</span>
                </div>
            </div>
        </div>
        
        <div class="md:col-span-7">
            <div class="card bg-base-100 shadow-md border-l-8 border-l-indigo-500 h-full p-8" data-aos="fade-left">
                <h5 class="text-xl font-bold mb-4 text-indigo-700">Main Improvements</h5>
                <p class="text-gray-700 text-lg leading-relaxed">
                    @(string.IsNullOrEmpty(Model.OverallImprovementSuggestions) ? "Keep practicing! You are doing great." : Model.OverallImprovementSuggestions)
                </p>
            </div>
        </div>
    </div>

    <h3 class="text-2xl font-bold mb-6 pb-2 border-b border-gray-200 text-gray-800">Detailed Feedback</h3>
        
    @if(Model.Results != null && Model.Results.Any())
    {
        for (int i = 0; i < Model.Results.Count; i++)
        {
            var r = Model.Results[i];
            var scoreColor = r.Score >= 80 ? "success" : r.Score >= 60 ? "warning" : "error";
            var bgLightColor = r.Score >= 80 ? "bg-green-50" : r.Score >= 60 ? "bg-yellow-50" : "bg-red-50";

            <div class="card bg-base-100 shadow-md mb-8 border-t-8 border-@scoreColor" data-aos="fade-up" data-aos-delay="@(i * 100)">
                <div class="card-body p-6 sm:p-8">
                    <div class="flex justify-between items-center mb-6">
                        <h5 class="text-xl font-bold text-gray-800">Question @(i + 1)</h5>
                        <span class="badge badge-@scoreColor badge-lg px-4 py-3 font-semibold text-white">
                            Score: @r.Score / 100
                        </span>
                    </div>
                    
                    <p class="text-lg font-medium text-gray-900 mb-6 leading-relaxed">@r.Question</p>
                    
                    <div class="p-5 bg-gray-50 rounded-xl mb-6 border border-gray-200">
                        <h6 class="text-gray-500 font-bold mb-2 uppercase text-sm tracking-wider">Your Answer:</h6>
                        <p class="text-gray-800 @(string.IsNullOrEmpty(r.UserAnswer) ? "italic text-gray-400" : "")">
                            @(string.IsNullOrEmpty(r.UserAnswer) ? "No answer provided" : r.UserAnswer)
                        </p>
                    </div>
                    
                    <div class="p-5 rounded-xl mb-6 border border-green-200 bg-green-50/50">
                        <h6 class="text-green-700 font-bold mb-3 uppercase text-sm tracking-wider flex justify-between items-center">
                            Ideal Answer
                        </h6>
                        <div class="tts-player mb-4 p-3 bg-white rounded-lg shadow-sm border border-gray-100 flex items-center gap-4" data-text="@r.IdealAnswer">
                            <button class="btn btn-circle btn-primary btn-sm play-pause-btn text-lg">
                                ▶
                            </button>
                            <input type="range" class="range range-xs range-primary flex-grow progress-slider" min="0" max="100" value="0">
                            <span class="time-display font-bold text-gray-500 text-sm w-12 text-right">0%</span>
                        </div>
                        <p class="text-gray-800 leading-relaxed">@r.IdealAnswer</p>
                    </div>
                    
                    <div class="p-5 rounded-xl @bgLightColor border border-@(scoreColor)/20">
                        <h6 class="font-bold mb-3 uppercase text-sm tracking-wider text-@scoreColor">Feedback:</h6>
                        <p class="text-gray-800 leading-relaxed">@r.Feedback</p>
                    </div>
                </div>
            </div>
        }
    }
        
    <div class="flex flex-col sm:flex-row justify-center items-center gap-4 mt-12 mb-8">
        <a asp-controller="Dashboard" asp-action="Index" class="btn btn-outline border-gray-300 text-gray-700 hover:bg-gray-50 rounded-full px-8 py-3 h-auto text-lg transition-all w-full sm:w-auto">Back to Dashboard</a>
        <a asp-controller="Interview" asp-action="Setup" class="btn bg-indigo-600 hover:bg-indigo-700 text-white border-none rounded-full px-8 py-3 h-auto text-lg shadow-md hover:shadow-lg transition-all w-full sm:w-auto">Practice Again ✨</a>
    </div>
</div>


@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const players = document.querySelectorAll('.tts-player');
            
            // Cleanup on leave
            window.addEventListener('beforeunload', () => { window.speechSynthesis.cancel(); });
            
            players.forEach(player => {
                const btn = player.querySelector('.play-pause-btn');
                const slider = player.querySelector('.progress-slider');
                const timeDisplay = player.querySelector('.time-display');
                const fullText = player.getAttribute('data-text');
                
                let utterance = null;
                let isPlaying = false;
                let isPaused = false;
                let currentBoundary = 0;
                
                function updateUI(percent) {
                    slider.value = percent;
                    timeDisplay.innerText = Math.round(percent) + '%';
                }

                function createUtterance(textToSpeak, startIndex = 0) {
                    const u = new SpeechSynthesisUtterance(textToSpeak);
                    u.rate = 1.0;
                    
                    u.onboundary = function(e) {
                        if (e.name === 'word') {
                            currentBoundary = startIndex + e.charIndex;
                            const percent = (currentBoundary / fullText.length) * 100;
                            updateUI(percent);
                        }
                    };
                    
                    u.onend = function() {
                        isPlaying = false;
                        isPaused = false;
                        btn.innerText = '▶';
                        updateUI(100);
                        setTimeout(() => updateUI(0), 1000);
                    };
                    
                    return u;
                }

                btn.addEventListener('click', () => {
                    if (!isPlaying) {
                        window.speechSynthesis.cancel();
                        
                        const startPercent = parseInt(slider.value) / 100;
                        currentBoundary = Math.floor(fullText.length * startPercent);
                        const textToSpeak = fullText.substring(currentBoundary);
                        
                        utterance = createUtterance(textToSpeak, currentBoundary);
                        window.speechSynthesis.speak(utterance);
                        
                        isPlaying = true;
                        isPaused = false;
                        btn.innerText = '⏸';
                    } else {
                        if (isPaused) {
                            window.speechSynthesis.resume();
                            isPaused = false;
                            btn.innerText = '⏸';
                        } else {
                            window.speechSynthesis.pause();
                            isPaused = true;
                            btn.innerText = '▶';
                        }
                    }
                });

                slider.addEventListener('input', (e) => {
                    const percent = e.target.value;
                    timeDisplay.innerText = Math.round(percent) + '%';
                });

                slider.addEventListener('change', (e) => {
                    if (isPlaying) {
                        window.speechSynthesis.cancel();
                        
                        const startPercent = parseInt(e.target.value) / 100;
                        currentBoundary = Math.floor(fullText.length * startPercent);
                        const textToSpeak = fullText.substring(currentBoundary);
                        
                        utterance = createUtterance(textToSpeak, currentBoundary);
                        window.speechSynthesis.speak(utterance);
                        if (isPaused) {
                            window.speechSynthesis.pause();
                        }
                    }
                });
            });
        });
    </script>
}
