@model AIInterviewPractice.Models.InterviewSession
@{
    ViewData["Title"] = "Interview Result";
}

<div class="row min-vh-75 justify-content-center mt-4 fade-in">
    <div class="col-md-10">
        <div class="text-center mb-5">
            <h1 class="display-5 fw-bold" style="color: var(--primary);">Interview Complete</h1>
            <p class="lead text-muted">Here is your detailed performance evaluation.</p>
        </div>

        <div class="row mb-5">
            <div class="col-md-5 mb-4 mb-md-0">
                <div class="card-modern h-100 d-flex flex-column align-items-center justify-content-center">
                    <h4 class="mb-4 fw-bold">Overall Score</h4>
                    
                    <div class="score-circle">
                        <svg width="150" height="150" style="position: absolute; top: 0; left: 0;">
                            <circle cx="75" cy="75" r="70" fill="none" stroke="#F3F4F6" stroke-width="8"></circle>
                            <circle cx="75" cy="75" r="70" fill="none" 
                                    stroke="@(Model.Score >= 80 ? "var(--accent)" : Model.Score >= 60 ? "var(--warning)" : "var(--danger)")" 
                                    stroke-width="8" 
                                    stroke-dasharray="439.8" 
                                    stroke-dashoffset="@(439.8 - (439.8 * Model.Score / 100))" 
                                    stroke-linecap="round"
                                    style="transform: rotate(-90deg); transform-origin: 50% 50%; transition: stroke-dashoffset 1.5s ease;"></circle>
                        </svg>
                        <span class="score-text text-dark">@Model.Score<span style="font-size: 1.5rem; color: var(--text-muted);">%</span></span>
                    </div>
                </div>
            </div>
            
            <div class="col-md-7">
                <div class="card-modern h-100" style="border-left: 5px solid var(--secondary);">
                    <h5 class="fw-bold mb-3 text-secondary">Main Improvements</h5>
                    <p class="text-dark fs-6" style="line-height: 1.6;">
                        @(string.IsNullOrEmpty(Model.OverallImprovementSuggestions) ? "Keep practicing! You are doing great." : Model.OverallImprovementSuggestions)
                    </p>
                </div>
            </div>
        </div>

        <h3 class="fw-bold mb-4 pb-2 border-bottom">Detailed Feedback</h3>
            
            @if(Model.Results != null && Model.Results.Any())
            {
                for (int i = 0; i < Model.Results.Count; i++)
                {
                    var r = Model.Results[i];
                    <div class="card-modern mb-5" style="border-top: 5px solid @(r.Score >= 80 ? "var(--accent)" : r.Score >= 60 ? "var(--warning)" : "var(--danger)")">
                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h5 class="mb-0 fw-bold">Question @(i + 1)</h5>
                            <span class="badge @(r.Score >= 80 ? "bg-success" : r.Score >= 60 ? "bg-warning text-dark" : "bg-danger") px-3 py-2 rounded-pill fs-6">
                                Score: @r.Score / 100
                            </span>
                        </div>
                        
                        <p class="fs-5 fw-medium text-dark mb-4">@r.Question</p>
                        
                        <div class="p-3 bg-light rounded-3 mb-4 border">
                            <h6 class="text-muted fw-bold mb-2">Your Answer:</h6>
                            <p class="mb-0 @(string.IsNullOrEmpty(r.UserAnswer) ? "fst-italic text-muted" : "text-dark")">
                                @(string.IsNullOrEmpty(r.UserAnswer) ? "No answer provided" : r.UserAnswer)
                            </p>
                        </div>
                        
                        <div class="p-3 rounded-3 mb-4" style="background-color: rgba(34, 197, 94, 0.05); border: 1px solid rgba(34, 197, 94, 0.2);">
                            <h6 class="text-success fw-bold mb-3 d-flex justify-content-between align-items-center">
                                Ideal Answer
                            </h6>
                            <div class="tts-player mb-3 p-2 bg-white rounded shadow-sm d-flex align-items-center" data-text="@r.IdealAnswer" style="gap: 15px;">
                                <button class="btn btn-primary rounded-circle play-pause-btn d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; padding: 0;">
                                    ▶
                                </button>
                                <input type="range" class="form-range flex-grow-1 progress-slider" min="0" max="100" value="0" style="cursor: pointer;">
                                <span class="time-display fw-bold text-muted" style="min-width: 45px; font-size: 0.85em;">0%</span>
                            </div>
                            <p class="mb-0 text-dark">@r.IdealAnswer</p>
                        </div>
                        
                        <div class="p-3 rounded-3" style="background-color: @(r.Score >= 80 ? "rgba(34, 197, 94, 0.1)" : r.Score >= 60 ? "rgba(245, 158, 11, 0.1)" : "rgba(239, 68, 68, 0.1)");">
                            <h6 class="fw-bold mb-2 @(r.Score >= 80 ? "text-success" : r.Score >= 60 ? "text-warning" : "text-danger")">Feedback:</h6>
                            <p class="mb-0 text-dark">@r.Feedback</p>
                        </div>
                    </div>
                }
            }
            
        <div class="text-center mt-5 mb-5 pb-4">
            <a asp-controller="Dashboard" asp-action="Index" class="btn btn-secondary-modern px-5 py-3 fs-5 me-3">Back to Dashboard</a>
            <a asp-controller="Interview" asp-action="Setup" class="btn btn-primary-modern px-5 py-3 fs-5 shadow">Practice Again ✨</a>
        </div>
    </div>
</div>


@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const players = document.querySelectorAll('.tts-player');
            
            // Cleanup on leave
            window.addEventListener('beforeunload', () => { window.speechSynthesis.cancel(); });
            
            players.forEach(player => {
                const btn = player.querySelector('.play-pause-btn');
                const slider = player.querySelector('.progress-slider');
                const timeDisplay = player.querySelector('.time-display');
                const fullText = player.getAttribute('data-text');
                
                let utterance = null;
                let isPlaying = false;
                let isPaused = false;
                let currentBoundary = 0;
                
                function updateUI(percent) {
                    slider.value = percent;
                    timeDisplay.innerText = Math.round(percent) + '%';
                }

                function createUtterance(textToSpeak, startIndex = 0) {
                    const u = new SpeechSynthesisUtterance(textToSpeak);
                    u.rate = 1.0;
                    
                    u.onboundary = function(e) {
                        if (e.name === 'word') {
                            currentBoundary = startIndex + e.charIndex;
                            const percent = (currentBoundary / fullText.length) * 100;
                            updateUI(percent);
                        }
                    };
                    
                    u.onend = function() {
                        isPlaying = false;
                        isPaused = false;
                        btn.innerText = '▶';
                        updateUI(100);
                        setTimeout(() => updateUI(0), 1000);
                    };
                    
                    return u;
                }

                btn.addEventListener('click', () => {
                    if (!isPlaying) {
                        window.speechSynthesis.cancel();
                        
                        const startPercent = parseInt(slider.value) / 100;
                        currentBoundary = Math.floor(fullText.length * startPercent);
                        const textToSpeak = fullText.substring(currentBoundary);
                        
                        utterance = createUtterance(textToSpeak, currentBoundary);
                        window.speechSynthesis.speak(utterance);
                        
                        isPlaying = true;
                        isPaused = false;
                        btn.innerText = '⏸';
                    } else {
                        if (isPaused) {
                            window.speechSynthesis.resume();
                            isPaused = false;
                            btn.innerText = '⏸';
                        } else {
                            window.speechSynthesis.pause();
                            isPaused = true;
                            btn.innerText = '▶';
                        }
                    }
                });

                slider.addEventListener('input', (e) => {
                    const percent = e.target.value;
                    timeDisplay.innerText = Math.round(percent) + '%';
                });

                slider.addEventListener('change', (e) => {
                    if (isPlaying) {
                        window.speechSynthesis.cancel();
                        
                        const startPercent = parseInt(e.target.value) / 100;
                        currentBoundary = Math.floor(fullText.length * startPercent);
                        const textToSpeak = fullText.substring(currentBoundary);
                        
                        utterance = createUtterance(textToSpeak, currentBoundary);
                        window.speechSynthesis.speak(utterance);
                        if (isPaused) {
                            window.speechSynthesis.pause();
                        }
                    }
                });
            });
        });
    </script>
}
